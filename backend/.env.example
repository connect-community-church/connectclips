# Copy to .env and fill in.

# Where raw sermon files / intermediate work / exported clips live.
# Once the secondary SSD is installed, switch these to /mnt/d/ConnectClips-data/...
DATA_SOURCES_DIR=/mnt/c/ConnectClips-data/sources
DATA_WORK_DIR=/mnt/c/ConnectClips-data/work
DATA_CLIPS_DIR=/mnt/c/ConnectClips-data/clips

# Anthropic API
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Whisper
WHISPER_MODEL=large-v3
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cuda

# Server (port 8000 is in use by something else on streaming-pc, so default to 8765)
# Run with: .venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8765

# Admin mode (frontend toggle that gates delete operations).
# Generate SESSION_SECRET with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
ADMIN_PASSWORD=
SESSION_SECRET=

# Comma-separated Tailscale logins (emails) that get admin rights
# automatically. Requires the app to be served behind ``tailscale serve``
# so identity headers are forwarded. Leave blank to use ADMIN_PASSWORD only.
ADMIN_TAILSCALE_LOGINS=
